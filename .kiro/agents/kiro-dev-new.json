{
  "name": "kiro-dev-new",
  "description": "Kiro CLI development agent",
  "model": "claude-opus-4.6-1m",
  "prompt": "file://resources/KIRO_DEV_PROMPT.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "code",
    "grep",
    "glob",
    "introspect",
    "knowledge",
    "todo_list",
    "subagent",
    "web_fetch",
    "web_search",
    "@ht-mcp",
    "@builder-mcp/ReadInternalWebsites",
    "@builder-mcp/InternalSearch"
  ],
  "allowedTools": [
    "fs_read",
    "grep",
    "glob",
    "introspect",
    "knowledge",
    "@ht-mcp"
  ],
  "useLegacyMcpJson": true,
  "keyboardShortcut": "ctrl+1",
  "welcomeMessage": "Hi! I'm the Kiro-Dev agent for CLI development.\n\nAvailable agents:\n- `oncall` - For Kiro CLI oncall activities\n\nAvailable workflows:\n- `@changelog` - Propose changelog entries for recent changes\n- `@release` - Generate release notes, bump version, and create PR\n- `@docs` - Update autodocs for code changes",
  "toolsSettings": {
    "execute_bash": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        "^git status$",
        "^git diff[^&;|]*$",
        "^git log[^&;|]*$",
        "^git add[^&;|]*$",
        "^git pull[^&;|]*$",
        "^git commit[^&;|]*$",
        "^git checkout[^&;|]*$",
        "^cargo clippy[^&;]*$",
        "^cargo \\+nightly fmt[^&;]*$",
        "^cargo build[^&;]*$",
        "^cargo test[^&;]*$",
        "^bun install$",
        "^bun test[^&;|]*$",
        "^bun run[^&;|]*$",
        "^\\./scripts/generate-types\\.sh$",
        "^jq[^&;|]*$",
        "^cat[^&;|]*$",
        "^ls[^&;|]*$",
        "^pwd$",
        "^wc[^&;|]*$",
        "^head[^&;|]*$",
        "^tail[^&;|]*$",
        "^grep[^&;|]*$",
        "^find[^&;|]*$",
        "^mkdir[^&;|]*$",
        "^gh pr view[^&;|]*$",
        "^gh pr list[^&;|]*$",
        "^gh pr diff[^&;|]*$",
        "^gh issue view[^&;|]*$"
      ]
    },
    "subagent": {
      "trustedAgents": [
        "kiro-research-agent"
      ],
      "availableAgents": [
        "kiro-research-agent",
        "kiro_default"
      ]
    }
  },
  "resources": [
    "skill://autodocs/README.md",
    "file://AGENTS.md",
    "file://README.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "git status",
        "description": "Add current git status to context"
      },
      {
        "command": "pwd",
        "description": "Add current directory to context"
      }
    ]
  }
}
