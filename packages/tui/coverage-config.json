{
  "coverageGoal": 90,
  "_comment": "Single source of truth for coverage exclusions. Only exclude test files, ink/deprecated code, and build artifacts. All production code stays in the denominator.",

  "excludePatterns": [
    { "pattern": "\\.test\\.", "reason": "Test files" },
    { "pattern": "\\.spec\\.", "reason": "Spec files" },
    { "pattern": "\\.vitest\\.", "reason": "Vitest test files" },
    { "pattern": "__tests__", "reason": "Test directories" },
    { "pattern": "test-utils/", "reason": "Test infrastructure" },
    { "pattern": "e2e_tests/", "reason": "E2E test infrastructure" },
    { "pattern": "storybook/", "reason": "Storybook dev tooling, not production code" },
    { "pattern": "coverage-preload", "reason": "Test infrastructure" },
    { "pattern": "ink/", "reason": "Vendored Ink fork, being replaced by twinki" },
    { "pattern": "dist/", "reason": "Build output" },
    { "pattern": "node_modules/", "reason": "Third-party dependencies" },
    { "pattern": "(^|/)renderer\\.ts$", "reason": "Ink/twinki switching proxy, deprecated" }
  ]
}
