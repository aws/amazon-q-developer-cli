{
  "name": "@kiro/tui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/start-dev.ts",
    "dev:storybook": "bun --watch src/storybook/run-storybook.tsx",
    "build": "bun build src/index.tsx --outfile dist/tui.js --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check src",
    "lint:fix": "eslint . --fix && prettier --write src",
    "format": "prettier --write src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:integ": "bun test ./integ_tests/",
    "test:e2e": "bun run scripts/run-e2e.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.5.1",
    "@xterm/headless": "^6.0.0",
    "ansi-escapes": "^7.2.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "ink": "6.6.0",
    "meow": "^13.2.0",
    "react": "^19.0.0",
    "supports-color": "^9.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "bun-pty": "^0.4.2",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "strip-ansi": "^7.0.0",
    "typescript": "^5.7.2"
  },
  "module": "src/index.tsx",
  "private": true
}
