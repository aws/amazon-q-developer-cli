{
  "name": "@kiro/tui",
  "version": "1.27.3",
  "type": "module",
  "overrides": {
    "react": "19.2.3"
  },
  "scripts": {
    "dev": "bun run scripts/start-dev.ts",
    "dev:256": "COLORTERM= bun run scripts/start-dev.ts",
    "release": "bun run scripts/start-release.ts",
    "dev:storybook": "bun --watch src/storybook/run-storybook.tsx",
    "build": "NODE_ENV=production bun build src/index.tsx --outfile dist/tui.js --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check src",
    "lint:fix": "eslint . --fix && prettier --write src",
    "format": "prettier --write src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:integ": "bun test ./integ_tests/",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "bench:markdown": "bun run scripts/benchmark-markdown.ts",
    "dev:profile": "KIRO_AGENT_PATH=../../target/debug/chat_cli_v2 KIRO_INPUT_METRICS=true KIRO_PERF_METRICS=true KIRO_TUI_LOG_FILE=/tmp/kiro-tui-perf.log bun --cpu-prof --cpu-prof-dir=./profiles --watch ./src/index.tsx",
    "dev:profiletui": "KIRO_RENDERER=twinki KIRO_AGENT_PATH=../../target/debug/chat_cli_v2 KIRO_INPUT_METRICS=true KIRO_PERF_METRICS=true KIRO_TUI_LOG_FILE=/tmp/kiro-tui-perf.log bun --cpu-prof --cpu-prof-dir=./profiles --watch ./src/index.tsx",
    "analyze:profile": "bun run scripts/analyze-profile.ts --html"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.5.1",
    "@types/diff": "^8.0.0",
    "@xterm/headless": "^6.0.0",
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.3",
    "ignore": "^7.0.5",
    "ink": "workspace:*",
    "meow": "^13.2.0",
    "react": "^19.2.4",
    "react-reconciler": "~0.33.0",
    "supports-color": "^9.4.0",
    "twinki": "workspace:*",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "bun-pty": "^0.4.8",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "strip-ansi": "^7.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "module": "src/index.tsx",
  "private": true
}
