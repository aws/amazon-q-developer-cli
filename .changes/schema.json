{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["type", "description"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["added", "changed", "deprecated", "removed", "fixed", "security"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  }
}
