[
  {
    "name": "invalid_denied_regex_denies_all",
    "commands": ["ls"],
    "settings": {
      "denied_commands": ["^(?!ls$).*"]
    },
    "detection": { "danger_level": "None", "is_readonly": true },
    "expected": "Deny",
    "expected_reason_contains": ["Invalid regex pattern"]
  },
  {
    "name": "order_1_deny_rule_wins_over_everything",
    "commands": ["rm file"],
    "settings": {
      "denied_commands": ["rm .*"],
      "allowed_commands": ["rm .*"],
      "is_tool_allowed": true,
      "auto_allow_readonly": true
    },
    "detection": { "danger_level": "None", "is_readonly": true },
    "expected": "Deny"
  },
  {
    "name": "order_2_tool_allowed_bypasses_dangerous",
    "commands": ["rm -rf /"],
    "settings": {
      "is_tool_allowed": true
    },
    "detection": { "danger_level": "High", "is_readonly": false },
    "expected": "Allow"
  },
  {
    "name": "order_3_dangerous_blocks_allowed_pattern",
    "commands": ["git commit -m \"$(whoami)\""],
    "settings": {
      "allowed_commands": ["git commit.*"]
    },
    "detection": { "danger_level": "High", "is_readonly": false },
    "expected": "Ask"
  },
  {
    "name": "order_4_allowed_and_readonly_permits_safe_commands",
    "commands": ["git log", "grep pattern"],
    "settings": {
      "allowed_commands": ["git .*"],
      "auto_allow_readonly": true
    },
    "detection": { 
      "danger_level": "None", 
      "is_readonly": false,
      "command_readonly": [false, true]
    },
    "expected": "Allow"
  },
  {
    "name": "order_5_deny_by_default_blocks_unpermitted",
    "commands": ["unknown_cmd"],
    "settings": {
      "deny_by_default": true
    },
    "detection": { "danger_level": "None", "is_readonly": false },
    "expected": "Deny"
  },
  {
    "name": "order_6_default_ask_unresolved",
    "commands": ["unknown_cmd"],
    "settings": {},
    "detection": { "danger_level": "None", "is_readonly": false },
    "expected": "Ask",
    "expected_trustable_commands": ["unknown_cmd"]
  },
  {
    "name": "chained_all_allowed_passes",
    "commands": ["git status", "git log"],
    "settings": {
      "allowed_commands": ["git .*"]
    },
    "detection": { "danger_level": "None", "is_readonly": false },
    "expected": "Allow"
  },
  {
    "name": "chained_partial_allow_asks",
    "commands": ["cd dir", "git status"],
    "settings": {
      "allowed_commands": ["git .*"]
    },
    "detection": { "danger_level": "None", "is_readonly": false },
    "expected": "Ask",
    "expected_trustable_commands": ["cd"]
  },
  {
    "name": "chained_any_deny_denies",
    "commands": ["ls", "rm file"],
    "settings": {
      "allowed_commands": ["ls"],
      "denied_commands": ["rm .*"]
    },
    "detection": { "danger_level": "None", "is_readonly": false },
    "expected": "Deny"
  },
  {
    "name": "dangerous_blocks_even_if_readonly",
    "commands": ["cat $(whoami)"],
    "settings": {
      "auto_allow_readonly": true
    },
    "detection": { "danger_level": "High", "is_readonly": true },
    "expected": "Ask"
  },
  {
    "name": "mixed_chain_deny_and_allow",
    "commands": ["git status", "rm -rf /", "ls"],
    "settings": {
      "allowed_commands": ["git .*"],
      "denied_commands": ["rm .*"],
      "auto_allow_readonly": true
    },
    "detection": {
      "danger_level": "None",
      "is_readonly": false,
      "command_readonly": [false, false, true]
    },
    "expected": "Deny"
  },
  {
    "name": "mixed_chain_allow_and_ask",
    "commands": ["git status", "unknown_cmd"],
    "settings": {
      "allowed_commands": ["git .*"]
    },
    "detection": {
      "danger_level": "None",
      "is_readonly": false,
      "command_readonly": [false, false]
    },
    "expected": "Ask",
    "expected_trustable_commands": ["unknown_cmd"]
  }
]
